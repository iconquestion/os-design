# Nachos build directories.
# These contain architecture-specific objects, dependencies, and binaries.
**/arch/

# Build outputs and generated dependency files.
*.o
*.d
*.coff
*.noff
*.flat

# Local executable links created by Makefile.common.
/bin/coff2noff
/bin/coff2flat
/bin/disassemble
/filesys/nachos
/lab2/nachos
/lab3/nachos
/lab5/nachos
/lab6/nachos
/lab7-8/nachos
/monitor/nachos
/network/nachos
/threads/nachos
/userprog/nachos
/vm/nachos

# User-program links created in test/.
/test/halt
/test/shell
/test/matmult
/test/sort
/test/exec
/test/exit
/test/join

# Nachos file-system disk images and runtime logs/results.
DISK
DISK2
log
log2
result

# Temporary files generated by Nachos examples and editors.
tmp*
*~

# Local editor configuration.
.vscode/
